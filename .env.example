### Environment template for https://github.com/growthepie/gtp-frontend ###

# -----------------------------------------------------------------------------
# Public app / runtime metadata
# -----------------------------------------------------------------------------

# Set to `development`, `preview`, or `production`.
NEXT_PUBLIC_VERCEL_ENV=development

# Local dev example: `localhost:3000`
NEXT_PUBLIC_VERCEL_URL=localhost:3000

# Preview branch hostname if you use branch-specific preview URLs.
NEXT_PUBLIC_VERCEL_BRANCH_URL=

# Canonical public site URL used by sitemap and metadata routes.
# Example: `https://www.growthepie.com`
NEXT_PUBLIC_SITE_URL=

# Production domain used in some deployment helpers.
# Format: `www.example.com`
PRODUCTION_DOMAIN=

# Local dev token sent to backend requests to bypass AWS WAF restrictions.
NEXT_PUBLIC_X_DEVELOPER_TOKEN=

# Toggle for old dev-only head/meta behavior.
IS_DEV=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------

# Google Tag Manager container ID.
NEXT_PUBLIC_GTM_ID=

# Google Analytics 4 measurement ID.
NEXT_PUBLIC_GA4_ID=

# -----------------------------------------------------------------------------
# Databases / backend services
# -----------------------------------------------------------------------------

# Fun DB connection string used by tracker / cron routes.
# Format: `postgresql://username:password@host:port/database`
FUN_DATABASE_URL=

# -----------------------------------------------------------------------------
# Airtable
# -----------------------------------------------------------------------------

# Airtable personal access token for notifications, contracts, donations, and labels survey APIs.
AIRTABLE_API_KEY=

# Airtable base ID used by labels survey ingestion.
AIRTABLE_BASE_ID=

# Airtable table ID used by labels survey ingestion.
AIRTABLE_SURVEY_TABLE_ID=

# -----------------------------------------------------------------------------
# AI / Gemini
# -----------------------------------------------------------------------------

# Gemini API key for labels project website profiler and contract classifier.
GEMINI_API_KEY=

# Optional Gemini model override.
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional Gemini API base override.
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Optional fallback aliases used by labels API routes.
GOOGLE_GENAI_API_KEY=
GOOGLE_API_KEY=

# -----------------------------------------------------------------------------
# Labels / OLI GitHub contribution flow
# -----------------------------------------------------------------------------

# GitHub token used to open contribution PRs.
OLI_GITHUB_TOKEN=

# Optional fallback alias for the same token.
GITHUB_TOKEN=

# Optional owner for contribution branches / PRs.
# Leave empty to use the authenticated GitHub user.
OLI_GITHUB_TARGET_OWNER=

# Whether to auto-create a fork when needed.
OLI_GITHUB_AUTO_CREATE_FORK=true

# Branch name prefix for contribution branches.
OLI_GITHUB_BRANCH_PREFIX=oli-contrib

# Disable in-memory rate limiting for local development only.
OLI_DISABLE_RATE_LIMIT=false

# -----------------------------------------------------------------------------
# Labels / OLI repository targets
# -----------------------------------------------------------------------------

# Project metadata repository target.
OLI_PROJECTS_REPO_OWNER=opensource-observer
OLI_PROJECTS_REPO_NAME=oss-directory
OLI_PROJECTS_REPO_BASE_BRANCH=main


# -----------------------------------------------------------------------------
# Webhooks / protected cron routes
# -----------------------------------------------------------------------------

# Shared secret for cron-style API routes.
CRON_SECRET=

# Secret used by the Vercel deployment webhook route.
VERCEL_DEPLOYMENT_WEBHOOK_SECRET=

# Discord webhook for deployment notifications.
DISCORD_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# External APIs
# -----------------------------------------------------------------------------

# Optimism vote endpoint for RPGF3 sync routes.
OPTIMISM_VOTE_ENDPOINT=https://vote.optimism.io/graphql

# -----------------------------------------------------------------------------
# Design / asset tooling
# -----------------------------------------------------------------------------

# Used by `/lib/figma.ts`, `/lib/figma-icons-library.ts`, and `/lib/figma-styles/run-me.ts`.
FIGMA_ACCESS_TOKEN=
FIGMA_FILE_KEY=
